# Generated by server_handler – do not edit manually.
# Re-generated every time the Minecraft server is started.
services:
{{- if .ZeroTier.Enabled }}
  {{ .ZeroTier.ContainerName }}:
    image: zerotier/zerotier
    container_name: {{ .ZeroTier.ContainerName }}
    network_mode: host
    cap_add:
      - NET_ADMIN
      - SYS_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    volumes:
      - {{ .ZeroTier.DataPath }}:/var/lib/zerotier-one
    entrypoint:
      - /bin/sh
      - -c
      - "zerotier-one & sleep 3 && zerotier-cli join {{ .ZeroTier.NetworkID }} && wait"
{{- if .ZeroTier.ApiSecret }}
    environment:
      ZEROTIER_API_SECRET: "{{ .ZeroTier.ApiSecret }}"
{{- end }}
{{- end }}
{{- if .Tailscale.Enabled }}
  {{ .Tailscale.ContainerName }}:
    image: tailscale/tailscale
    container_name: {{ .Tailscale.ContainerName }}
    network_mode: host
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    devices:
      - /dev/net/tun:/dev/net/tun
    volumes:
      - {{ .Tailscale.DataPath }}:/var/lib/tailscale
    environment:
      TS_AUTHKEY: "{{ .Tailscale.AuthKey }}"
      TS_STATE_DIR: "/var/lib/tailscale"
{{- if .Tailscale.Hostname }}
      TS_HOSTNAME: "{{ .Tailscale.Hostname }}"
{{- end }}
{{- end }}

  {{ .Docker.ContainerName }}:
    image: itzg/minecraft-server{{- if .Minecraft.JavaVersion }}:{{ .Minecraft.JavaVersion }}{{ end }}
    container_name: {{ .Docker.ContainerName }}
{{- if .ZeroTier.Enabled }}
    depends_on:
      - {{ .ZeroTier.ContainerName }}
{{- else if .Tailscale.Enabled }}
    depends_on:
      - {{ .Tailscale.ContainerName }}
{{- end }}
    ports:
      - "25565:25565"
      - "25575:25575"
    environment:
      EULA: "TRUE"
      TYPE: "{{ .Minecraft.Type }}"
      VERSION: "{{ .Minecraft.Version }}"
      ENABLE_RCON: "true"
      RCON_PASSWORD: "{{ .Minecraft.RconPassword }}"
{{- if .Minecraft.FabricLoaderVersion }}
      FABRIC_LOADER_VERSION: "{{ .Minecraft.FabricLoaderVersion }}"
{{- end }}
{{- if .Minecraft.ForgeVersion }}
      FORGE_VERSION: "{{ .Minecraft.ForgeVersion }}"
{{- end }}
{{- if .Minecraft.ModpackURL }}
      MODPACK: "{{ .Minecraft.ModpackURL }}"
{{- end }}
{{- range $k, $v := .Minecraft.ExtraEnv }}
      {{ $k }}: "{{ $v }}"
{{- end }}
    volumes:
      - {{ .Docker.DataPath }}:/data
    stdin_open: true
    tty: true
